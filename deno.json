{
  "name": "@scarf/conventional-prs",
  "version": "0.5.0",
  "license": "AGPL-3.0-only",
  "exports": "./mod.ts",
  "imports": {
    "@std/assert/equals": "jsr:@std/assert@^1.0.19/equals",
    "@std/testing/snapshot": "jsr:@std/testing@^1.0.16/snapshot",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "esbuild": "npm:esbuild@0.25.12"
  },
  "tasks": {
    "test": "deno test -R --doc --parallel",
    "build": {
      "description": "Build native + wasm",
      "dependencies": [
        "build:native",
        "build:wasm",
        "build:action"
      ]
    },
    "build:native": "cargo build --release",
    "build:wasm": "deno task wasmbuild",
    "build:action": {
      "description": "Bundle GitHub Action",
      "dependencies": [
        "build:wasm"
      ],
      "command": "deno run -A scripts/build-action.mjs"
    },
    "build:action:check": {
      "description": "Check GitHub Action bundle",
      "dependencies": [
        "build:wasm"
      ],
      "command": "deno run -A scripts/build-action.mjs --check"
    },
    "bench": {
      "description": "Benchmark CLI vs wasm",
      "dependencies": [
        "build"
      ],
      "command": "BENCH_INPUT='feat(api): add recovery' BENCH_CONFIG_PATH='.github/semantic.yml' BENCH_RUNS=10 BENCH_WARMUP=3 ./scripts/benchmark-cli-vs-wasm.sh"
    },
    "wasmbuild": "deno run -A jsr:@deno/wasmbuild@0.21.0 --project rs_lib",
    "wasmbuild:check": "deno task wasmbuild --check"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "deno.json",
      "action/package.json",
      "mod.ts",
      "lib/rs_lib.d.ts",
      "lib/rs_lib.js",
      "lib/rs_lib.internal.js",
      "lib/rs_lib.wasm"
    ]
  },
  "fmt": {
    "semiColons": false,
    "proseWrap": "never"
  },
  "lint": {
    "exclude": [
      "action/dist",
      "lib/rs_lib.d.ts",
      "lib/rs_lib.js",
      "lib/rs_lib.internal.js"
    ]
  }
}
